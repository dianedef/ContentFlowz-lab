# ⚠️  THIS FILE IS FOR LOCAL DEV FALLBACK ONLY
# ⚠️  PRODUCTION USES DOPPLER FOR SECRET MANAGEMENT
# 
# To configure secrets properly:
#   doppler secrets set KEY=value
#   OR use: https://dashboard.doppler.com
#
# This .env is only used when Doppler is not configured

# LLM API Keys

# RECOMMENDED: OpenRouter (50-90% cheaper, 100+ models, single API key)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Get free $5 credit: https://openrouter.ai/keys
USER_SECRETS_MASTER_KEY=replace_with_a_long_random_secret

# FALLBACK: Groq (FREE but limited models)
GROQ_API_KEY=your_groq_api_key_here
# Get your free key at: https://console.groq.com

# Data Collection APIs
EXA_API_KEY=your_exa_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# DataForSEO API v3 (SERP, keywords, trends, competitors, backlinks)
# Sign up at: https://app.dataforseo.com/register
DATAFORSEO_LOGIN=your_dataforseo_login_here
DATAFORSEO_PASSWORD=your_dataforseo_password_here

# STORM Research APIs (choose one for search)
YDC_API_KEY=your_you_api_key_here           # You.com API (recommended for STORM)
# SERPER_API_KEY=your_serper_api_key_here  # Alternative: Serper for Google results

# Email Service (Sending)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=your_email@example.com

# =============================================================================
# Newsletter Robot Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Email Backend Selection
# Options: "imap" (free, recommended) or "composio" (paid)
# -----------------------------------------------------------------------------
NEWSLETTER_EMAIL_BACKEND=imap

# -----------------------------------------------------------------------------
# IMAP Configuration (when NEWSLETTER_EMAIL_BACKEND=imap)
# Setup:
#   1. Enable 2FA on Gmail
#   2. Generate App Password at: Google Account → Security → App Passwords
#   3. Create Gmail labels: "Newsletters" and "CONTENTFLOW_DONE"
# -----------------------------------------------------------------------------
NEWSLETTER_IMAP_EMAIL=your-newsletters@gmail.com
NEWSLETTER_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NEWSLETTER_IMAP_HOST=imap.gmail.com
NEWSLETTER_IMAP_FOLDER=Newsletters
NEWSLETTER_IMAP_ARCHIVE=CONTENTFLOW_DONE

# -----------------------------------------------------------------------------
# Composio Configuration (when NEWSLETTER_EMAIL_BACKEND=composio)
# Setup: composio add gmail
# -----------------------------------------------------------------------------
# COMPOSIO_API_KEY=your_composio_api_key_here

# -----------------------------------------------------------------------------
# Newsletter Output Settings
# -----------------------------------------------------------------------------
NEWSLETTER_FROM_EMAIL=newsletter@example.com
NEWSLETTER_FROM_NAME=My Newsletter

# =============================================================================
# Mem0 Memory Layer Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Selection: "local" (default, ChromaDB) or "hosted" (Mem0 Platform)
# -----------------------------------------------------------------------------
MEM0_BACKEND=local

# Hosted only — Mem0 Platform API key (https://app.mem0.ai)
# MEM0_API_KEY=your_mem0_api_key_here

# LLM for Mem0 fact extraction (default: gpt-4o-mini)
# MEM0_LLM_MODEL=gpt-4o-mini

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Clerk auth
CLERK_JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
FEEDBACK_ADMIN_EMAILS=admin@example.com,ops@example.com
FEEDBACK_SIGNING_SECRET=your_feedback_signing_secret

# =============================================================================
# Status Tracking Configuration
# =============================================================================
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# =============================================================================
# Image Robot Configuration (Robolly + Bunny.net)
# =============================================================================

# -----------------------------------------------------------------------------
# Robolly API (Image Generation)
# Get your API key at: https://robolly.com/dashboard
# -----------------------------------------------------------------------------
ROBOLLY_API_KEY=your_robolly_api_key_here

# Template IDs (create these in Robolly dashboard)
ROBOLLY_TEMPLATE_HERO=your_hero_template_id
ROBOLLY_TEMPLATE_SECTION=your_section_template_id
ROBOLLY_TEMPLATE_OG=your_og_card_template_id
ROBOLLY_TEMPLATE_THUMBNAIL=your_thumbnail_template_id

# -----------------------------------------------------------------------------
# Bunny.net CDN (Image Storage & Delivery)
# Get your API keys at: https://dash.bunny.net/account/apikey
# -----------------------------------------------------------------------------
BUNNY_STORAGE_API_KEY=your_bunny_storage_api_key
BUNNY_CDN_API_KEY=your_bunny_cdn_api_key
BUNNY_STORAGE_ZONE=contentflow-images
BUNNY_CDN_HOSTNAME=your-zone.b-cdn.net
BUNNY_PULL_ZONE_ID=123456
BUNNY_STORAGE_REGION=de
FEEDBACK_UPLOAD_TTL_SECONDS=900
FEEDBACK_PLAYBACK_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Brand Configuration (for Robolly templates)
# -----------------------------------------------------------------------------
BRAND_COLOR_PRIMARY=#2563eb
BRAND_COLOR_SECONDARY=#64748b
BRAND_LOGO_URL=https://your-cdn.com/logo.png

# =============================================================================
# Performance Monitoring
# =============================================================================

# Google PageSpeed Insights API key (free, 25,000 req/day)
# Get your key at: https://console.developers.google.com → Enable "PageSpeed Insights API"
GOOGLE_PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

# =============================================================================
# Google Search Console + Indexing API (publishing pipeline)
# =============================================================================
# Setup:
#   1. Google Cloud Console → IAM → Service Accounts → Create → Download JSON key
#   2. Enable APIs: "Indexing API" + "Search Console API" in Cloud Console
#   3. Google Search Console → Settings → Users and permissions → Add service account email as Owner
#   4. Docs: https://developers.google.com/search/apis/indexing-api/v3/quickstart
# -----------------------------------------------------------------------------
# Preferred (used by api/services/gsc_client.py)
GSC_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
# Optional alternative: inline JSON (avoid committing secrets)
# GSC_SERVICE_ACCOUNT_DATA='{"type":"service_account", ... }'
#
# Legacy aliases (also supported):
# GOOGLE_CREDENTIALS_FILE=/path/to/service_account.json
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account", ... }'
# Site URL as registered in Search Console (with trailing slash if needed)
# Use https://your-site.com OR sc-domain:your-site.com for domain properties
GOOGLE_SITE_URL=https://your-site.com

# =============================================================================
# GitHub Access (required for private repos)
# =============================================================================
# Personal Access Token — needed to clone private GitHub repos
# Create at: https://github.com/settings/tokens → "repo" scope
GITHUB_TOKEN=your_github_token_here
OPENAI_API_KEY=

# =============================================================================
# Additional runtime/env variables detected in repo
# =============================================================================

# API Keys
ANTHROPIC_API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LATE_API_KEY=
OPENAI_IMAGE_MODEL=
CONSENSUS_API_KEY=

# Clerk auth aliases and claims
CLERK_AUDIENCE=
CLERK_ISSUER=
CLERK_JWT_AUDIENCE=

# LLM/agent/platform behavior
AI_PLATFORM_MODE_ENABLED=
AI_PLATFORM_MODE_ALLOWED_USER_IDS=

# Search and enrichment services
SERP_API_KEY=
# YDC_API_KEY already defined in the Research APIs section above

# Git metadata / deployment
BACKEND_GIT_SHA=
RENDER_GIT_COMMIT=
GIT_SHA=
PORT=8000
APP_URL=https://your-app-url.example

# Brand rendering (images/templates)
BRAND_COLOR_ACCENT=#f59e0b
BRAND_COLOR_BG=#ffffff
BRAND_COLOR_TEXT=#1f2937
BRAND_FONT=Inter
BRAND_LOGO_DARK_URL=

# Identity / integrations
COMPOSIO_API_KEY=
GITHUB_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_SCOPES=repo,user
GITHUB_REPO=your-org/your-repo

# Service credentials & paths
IMAGE_ROBOT_DATA_DIR=/root/contentflow_lab/data/images
IMAGE_ROBOT_LLM_MODEL=gpt-4o-mini
IMAGE_ROBOT_LLM_TEMPERATURE=0.3
IMAGE_ROBOT_LOG_LEVEL=INFO
IMAGE_ROBOT_TEMP_DIR=/tmp/image-robot
MEM0_API_KEY=
MEM0_LLM_MODEL=gpt-4o-mini
NEWSLETTER_LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
NEWSLETTER_IMAP_DAYS=7
NEWSLETTER_IMAP_MAX_EMAILS=20
PROJECT_PATH=/root/contentflow_lab

# Scheduler runtime
SCHEDULER_AUDIT_FREQUENCY=weekly
SCHEDULER_AUTO_FIX=false
SCHEDULER_BASE_URL=http://localhost:3000
SCHEDULER_COST_CRITICAL=500.0
SCHEDULER_COST_WARNING=100.0
SCHEDULER_DATA_DIR=/root/contentflow_lab/data/scheduler
SCHEDULER_LLM_MODEL=mixtral-8x7b-32768
SCHEDULER_LLM_TEMPERATURE=0.3
SCHEDULER_NOTIFY_EMAIL=
SCHEDULER_NOTIFY_ON_CRITICAL=true
SCHEDULER_NOTIFY_SLACK_WEBHOOK=
SCHEDULER_PERF_BUILD_TIME=120
SCHEDULER_PERF_PAGE_SPEED=90
SCHEDULER_PERF_SEO_SCORE=85
SCHEDULER_PRODUCTION_URL=https://yoursite.com
SCHEDULER_PROJECT_PATH=/root/contentflow_lab

# Publishing and webhook config
PUBLISH_AUTO_DEPLOY=true
PUBLISH_REQUIRE_APPROVAL=false
PUBLISH_TIMEZONE=America/New_York

# Google credentials aliases
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_INDEXING_API_KEY=
GOOGLE_SEARCH_CONSOLE_CREDENTIALS=

GSC_SERVICE_ACCOUNT_DATA=

# External service integrations
ZERNIO_API_KEY=

# DB
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Runtime
UVICORN_RELOAD=false
